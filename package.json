{
  "name": "cogitador-consulta",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "scrape:mfm": "node scripts/scrape-mfm.mjs",
    "update:costs": "node scripts/update-costs.mjs",
    "generate:faction-data": "TSX_TSCONFIG_PATH=./scripts/tsconfig.json tsx scripts/generate-faction-data.ts",
    "verify:faction-data": "TSX_TSCONFIG_PATH=./scripts/tsconfig.json tsx scripts/verify-faction-data.ts",
    "typecheck:scripts": "tsc --noEmit -p scripts/tsconfig.json"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.12.0",
    "lz-string": "^1.5.0",
    "papaparse": "^5.5.3",
    "qr-scanner": "^1.4.2",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-redux": "^9.3.0",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.13.2",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.23.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.12"
  }
}
